{
  "$version": "1.0",
  "description": "Registry of government schemes, programmes, missions, and funds for the CAG audit report repository. IDs use GOI-SCH-{ABBR} for central schemes and IN-{ST}-SCH-{ABBR} for state schemes. IDs are permanently stable — they never change on rename. Each scheme phase (PMGSY, PMGSY-II, PMGSY-III) is a separate entry linked by predecessor/successor IDs. Merged, subsumed, or discontinued schemes remain with active=false + archived=true for historical report resolution.",
  "id_convention": {
    "description": "ID prefix encodes jurisdiction and distinguishes schemes from entities.",
    "prefixes": [
      {
        "prefix": "GOI-SCH",
        "meaning": "Central Government Scheme / Programme / Mission"
      },
      {
        "prefix": "GOI-FUND",
        "meaning": "Central Government Fund or Corpus"
      },
      {
        "prefix": "IN-{ST}-SCH",
        "meaning": "State Scheme — ST = ISO 3166-2 state code e.g. IN-MP-SCH"
      }
    ]
  },
  "scheme_type_values": [
    "centrally_sponsored_scheme",
    "central_sector_scheme",
    "state_scheme",
    "mission",
    "programme",
    "fund",
    "yojana",
    "abhiyan",
    "other"
  ],
  "status_values": [
    "active",
    "discontinued",
    "merged",
    "subsumed",
    "completed",
    "renamed"
  ],

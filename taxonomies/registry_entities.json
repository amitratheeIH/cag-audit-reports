{
  "$version": "1.0",
  "description": "Registry of government entities for the CAG audit report repository. Covers central ministries, departments, attached/subordinate offices, PSUs, statutory bodies, constitutional bodies, and state-level departments. IDs are permanently stable — they never change even if the entity is renamed or restructured. active=false + archived=true for dissolved entities; these remain in this file for ID resolution of historical reports. state-level entries use IN-{STATE}-{TYPE}-{ABBR} format.",
  "id_convention": {
    "description": "ID prefix encodes jurisdiction and entity type.",
    "prefixes": [
      {
        "prefix": "GOI-MIN",
        "meaning": "Central Government Ministry"
      },
      {
        "prefix": "GOI-DEPT",
        "meaning": "Central Government Department (under a Ministry)"
      },
      {
        "prefix": "GOI-OFF",
        "meaning": "Central Government Attached or Subordinate Office"
      },
      {
        "prefix": "GOI-PSU",
        "meaning": "Central Public Sector Undertaking"
      },
      {
        "prefix": "GOI-AUTH",
        "meaning": "Central Government Authority or Board"
      },
      {
        "prefix": "CONST",
        "meaning": "Constitutional Body (independent of executive)"
      },
      {
        "prefix": "STAT",
        "meaning": "Statutory Body (created by Act of Parliament)"
      },
      {
        "prefix": "IN-{ST}-DEPT",
        "meaning": "State/UT Department — ST = ISO 3166-2 state code e.g. IN-MP-DEPT"
      },
      {
        "prefix": "IN-{ST}-PSU",
        "meaning": "State/UT Public Sector Undertaking"
      },
      {
        "prefix": "IN-{ST}-AUTH",
        "meaning": "State/UT Authority or Board"
      }
    ]
  },
  "level_values": [
    "ministry",
    "department",
    "attached_office",
    "subordinate_office",
    "authority",
    "board",
